{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "nest-graph-inspector/nest-graph-inspector": "<rootDir>/../libs/nest-graph-inspector/src",
    "nest-graph-inspector/nest-graph-inspector/(.*)": "<rootDir>/../libs/nest-graph-inspector/src/$1"
  }
}